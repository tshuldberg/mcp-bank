# Wallet that receives x402 payments (USDC on Base)
WALLET_ADDRESS=0xYourWalletAddressHere

# Coinbase CDP credentials for x402 facilitation
CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret

# Redis connection (KV operations + TTL)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL + pgvector (vector search + metadata)
DATABASE_URL=postgresql://user:password@localhost:5432/memorystore

# Internal admin key for protected operations
ADMIN_KEY=your-secure-admin-key-here

# Service environment
ENVIRONMENT=development

# Public base URL (used in A2A agent card)
BASE_URL=https://mcp-bank-memory.fly.dev
